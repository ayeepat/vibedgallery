# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets, even publishable ones.

# Supabase — find these in Dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# Cloudflare Turnstile — publishable site key (the secret key lives in
# Supabase Function Secrets as TURNSTILE_SECRET_KEY). Leave blank for local
# dev to bypass the captcha entirely.
VITE_TURNSTILE_SITE_KEY=

# Base URL the app is served from. http://localhost:5173 for dev,
# https://your-domain in production.
VITE_APP_BASE_URL=http://localhost:5173

# Sentry error monitoring (optional). Create a free project at sentry.io,
# paste its DSN here AND into Vercel env vars. Leave blank to disable —
# the SDK is not even bundled without it.
VITE_SENTRY_DSN=
